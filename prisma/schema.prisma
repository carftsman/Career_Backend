generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  jobs Job[]
}

model Candidate {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  phone     String
  password  String
  dob       DateTime?
  location  String?
  skills    String?
  resumeUrl String?
  createdAt DateTime @default(now())

  // Forgot Password fields
  resetToken       String?
  resetTokenExpiry DateTime?

  applications Application[]
  savedJobs    SavedJob[]
  profile      CandidateProfile?
}

model Job {
  id          Int      @id @default(autoincrement())
  
  jobId       String?  @unique   
  hrEmail     String?            
  hrPhone     String?            

  title       String
  department  String
  location    String

  minExperience Int?
  maxExperience Int?
  experienceLabel String?
  jobType     String

  description String
  responsibilities String?
  skills      String[]
 
  salaryRange String?
  minSalary   Int?
  maxSalary   Int?
  currency    String?
  deadline    DateTime
  status      JobStatus @default(ACTIVE)


  createdAt   DateTime @default(now())

  createdById Int
  createdBy   User @relation(fields: [createdById], references: [id])

  applications Application[]
  savedJobs    SavedJob[]
}

model Application {
  id Int @id @default(autoincrement())

  candidateId Int
  candidate Candidate @relation(fields: [candidateId], references: [id])

  jobId Int
  job Job @relation(fields: [jobId], references: [id])

  // Personal info snapshot
  firstName String
  lastName String
  email String
  phone String
  gender String?
  dob DateTime?
  address String?
  city String?
  state String?
  country String?

  // Education
  qualification String?
  degree String?
  university String?
  graduationYear Int?
  cgpa Float?

  // Work Experience
  totalExperience Int?
  currentCompany String?
  currentRole String?
  previousCompanies String?
  achievements String?

  // Resume
  resumeUrl String?

  // Additional info
  skills String[]
  certifications String[]
  languages String[]

  status ApplicationStatus @default(APPLIED)

  createdAt DateTime @default(now())

  @@unique([candidateId, jobId])
}

model SavedJob {
  id Int @id @default(autoincrement())

  candidateId Int
  candidate Candidate @relation(fields: [candidateId], references: [id])

  jobId Int
  job Job @relation(fields: [jobId], references: [id])

  createdAt DateTime @default(now())

  @@unique([candidateId, jobId])
}

model CandidateProfile {
  id           Int      @id @default(autoincrement())

  candidateId  Int      @unique
  candidate    Candidate @relation(fields: [candidateId], references: [id])

  // Personal
  dob          DateTime?
  gender       String?
  address      String?
  city         String?
  state        String?
  country      String?
  photoUrl     String?

  // Education
  qualification   String?
  degree          String?
  university      String?
  graduationYear  Int?
  cgpa            Float?

  // Experience
  totalExperience Int?
  currentCompany  String?
  currentRole     String?
  previousCompanies String?

  // Extra
  skills         String[]
  certificateUrls String[]
  languages      String[]

  createdAt DateTime @default(now())
}

enum Role {
  HR
  MANAGER
  CANDIDATE
}

enum JobStatus {
  ACTIVE
  CLOSED
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  REJECTED
  HIRED
}